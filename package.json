{
  "name": "claude-code-for-copilot",
  "displayName": "Claude Code for Copilot Chat",
  "description": "Use Claude Code CLI directly in GitHub Copilot Chat. Zero config, uses your existing Claude Code installation.",
  "version": "0.3.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nanami016/Claude-Code-for-Copilot-Chat"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "claude",
    "claude code",
    "copilot",
    "github copilot",
    "copilot chat",
    "language model",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "claude-code-cli",
        "displayName": "Claude Code CLI"
      }
    ],
    "commands": [
      {
        "command": "claude-code-copilot.showLogs",
        "title": "Claude Code: Show Logs"
      },
      {
        "command": "claude-code-copilot.checkStatus",
        "title": "Claude Code: Check CLI Status"
      }
    ],
    "configuration": {
      "title": "Claude Code for Copilot",
      "properties": {
        "claude-code-copilot.cliPath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable"
        },
        "claude-code-copilot.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default Claude model to use (leave empty for CLI default)"
        },
        "claude-code-copilot.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": [
            "default",
            "acceptEdits",
            "bypassPermissions",
            "plan"
          ],
          "description": "Permission mode for Claude Code CLI. In interactive stdin mode (non-TTY), 'acceptEdits' or 'bypassPermissions' is recommended since permission prompts cannot be displayed."
        },
        "claude-code-copilot.interactiveMode": {
          "type": "boolean",
          "default": true,
          "description": "Use interactive stdin mode to enable Claude Code plugins and hooks (e.g. nowledge-mem). Disable to use faster -p print mode (no plugin/hook support)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^10.5.0",
    "typescript": "^5.7.0"
  }
}
